#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>

void main(void)

{
  p();
  return;
}

void p(void)
{
    void *ret_addr = __builtin_return_address(0);
    char buffer[76];

    fflush(stdout);
    gets(buffer);

    if (((unsigned int)ret_addr & 0xb0000000) == 0xb0000000) {
        // protection against return address overwrite
        printf("(%p)\n", ret_addr);
        _exit(1);
    }

    puts(buffer);
    strdup(buffer);
}